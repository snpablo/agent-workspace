flowchart TD
    subgraph WORK[Collaboration and Work]
      PROJ[Project]
      AG[Agent]
      SK[Skill]
      ART[Artifact]
      TH[Thread]
      RUN[Run]
      RES[Resource]
      SCH[Schedule]
      CH[Channel]
    end

    subgraph INTEG[Integration and Capability]
      CONN[Connector]
      TOOL[Tool]
    end

    subgraph RUNTIME[Runtime Records and State]
      EVT[Event]
      AS[AgentSession]
      PSTATE[Projected Current State]
    end

    PROJ --> AG
    AG --> SK
    AG --> CH
    AG --> CONN
    CONN --> TOOL
    TOOL --> RUN
    RUN --> EVT
    EVT --> PSTATE
    EVT --> AS
    PSTATE --> ART
    PSTATE --> TH
    PSTATE --> RES
    PSTATE --> SCH
