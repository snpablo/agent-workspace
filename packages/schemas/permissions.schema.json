{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workspace.dev/schemas/permissions.schema.json",
  "title": "Permissions",
  "type": "object",
  "required": ["id", "version", "rules"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "rules": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "permissionRef": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
