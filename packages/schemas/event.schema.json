{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workspace.dev/schemas/event.schema.json",
  "title": "Event",
  "type": "object",
  "required": ["id", "name", "timestamp", "workspaceId"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "pattern": "^[a-z_]+\\.[a-z_]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "workspaceId": { "type": "string" },
    "runId": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
