{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workspace.dev/schemas/workspace-definition.schema.json",
  "title": "WorkspaceDefinition",
  "type": "object",
  "required": ["workspace", "zones", "bindings"],
  "properties": {
    "workspace": {
      "type": "object",
      "required": ["id", "type", "version"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "displayName": { "type": "string" },
        "layout": { "type": "string" }
      },
      "additionalProperties": false
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/zone" }
    },
    "bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/binding" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRef" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/typeRef" }
    },
    "playbooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/typeRef" }
    },
    "policies": {
      "type": "array",
      "items": { "$ref": "policies.schema.json#/$defs/policyRef" }
    },
    "permissions": {
      "type": "array",
      "items": { "$ref": "permissions.schema.json#/$defs/permissionRef" }
    }
  },
  "$defs": {
    "zone": {
      "type": "object",
      "required": ["key", "component"],
      "properties": {
        "key": { "type": "string" },
        "component": { "type": "string" },
        "placement": { "type": "string" },
        "priority": { "type": "string" },
        "collapsible": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "binding": {
      "type": "object",
      "required": ["zone", "objectKind", "view"],
      "properties": {
        "zone": { "type": "string" },
        "objectKind": { "type": "string" },
        "selectionMode": { "type": "string" },
        "view": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifactRef": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "primary": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "typeRef": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
